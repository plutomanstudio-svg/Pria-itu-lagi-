// =====================================
// TAMPIL TENGAH
// =====================================

void tampil(String atas, String bawah, int waktu) {

  display.clearDisplay();

  display.setTextSize(1);
  display.setTextColor(SSD1306_WHITE);

  int16_t x1, y1;
  uint16_t w, h;

  // BARIS ATAS
  display.getTextBounds(atas, 0, 0, &x1, &y1, &w, &h);
  int xt = (128 - w) / 2;

  display.setCursor(xt, 18);
  display.println(atas);

  // BARIS BAWAH
  if (bawah != "") {

    display.getTextBounds(bawah, 0, 0, &x1, &y1, &w, &h);
    int xb = (128 - w) / 2;

    display.setCursor(xb, 38);
    display.println(bawah);
  }

  display.display();

  delay(waktu);
}

// =====================================
// SETUP
// =====================================

void setup() {

  // SDA = D2
  // SCL = D1
  Wire.begin(D2, D1);

  if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    while (true);
  }

  display.clearDisplay();
  display.display();
}

// =====================================
// LOOP
// =====================================

void loop() {

  tampil("EMPAT SETENGAH", "TAHUN...", 2200);

  tampil("SAYA", "DIFITNAH...", 2200);

  tampil("SAYA DIAM...", "", 1800);

  tampil("DIJELEK-", "JELEKIN...", 2200);

  tampil("SAYA DIAM...", "", 1800);

  tampil("DIHUJAT-", "HUJAT...", 2200);

  tampil("DIHINA-", "HINA...", 2200);

  tampil("SAYA DIAM...", "", 1800);

  tampil("TETAPI", "HARI INI...", 2200);

  tampil("SAYA", "SAMPAIKAN...", 2200);

  // =====================================
  // ANIMASI LAWAN
  // =====================================

  for (int i = 0; i < 8; i++) {

    display.clearDisplay();

    display.setTextColor(SSD1306_WHITE);

    display.setTextSize(1);
    display.setCursor(28, 8);
    display.println("SAYA AKAN");

    display.setTextSize(2);

    // EFEK GETAR
    display.setCursor(8, 30 + (i % 2) * 3);
    display.println("LAWAN!");

    display.display();

    delay(180);
  }

  // =====================================
  // EFEK KEDIP
  // =====================================

  for (int i = 0; i < 8; i++) {

    display.invertDisplay(true);
    delay(70);

    display.invertDisplay(false);
    delay(70);
  }

  // =====================================
  // GAMBAR PRABOWO GERAK
  // =====================================

  for (int x = 0; x <= 6; x += 1) {

    display.clearDisplay();

    display.drawBitmap(
      x,
      0,
      epd_bitmap_ChatGPT_Image_15_Mei_2026__07,
      128,
      64,
      SSD1306_WHITE
    );

    display.display();

    delay(80);
  }

  for (int x = 6; x >= 0; x -= 1) {

    display.clearDisplay();

    display.drawBitmap(
      x,
      0,
      epd_bitmap_ChatGPT_Image_15_Mei_2026__07,
      128,
      64,
      SSD1306_WHITE
    );

    display.display();

    delay(80);
  }

  // =====================================
  // HIDUP JOKOWI
  // =====================================

  for (int i = 0; i < 8; i++) {

    display.clearDisplay();

    if (i % 2 == 0) {

      display.setTextSize(2);

      display.setCursor(18, 16);
      display.println("HIDUP");

      display.setCursor(8, 42);
      display.println("JOKOWI");
    }

    display.display();

    delay(250);
  }

  delay(2500);
}
